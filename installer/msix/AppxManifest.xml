<?xml version="1.0" encoding="utf-8"?>
<!--
  Manifiesto MSIX para la Microsoft Store.
  La versión (x.y.z.0) se reemplaza al empaquetar (package-msix.ps1).
  Identidad asignada por Partner Center (producto «ingepresupuestos»):
    Name      = MarcoSumari.ingepresupuestos
    Publisher = CN=EE1CAE53-5428-4D95-AE8B-871AB9D0193C
-->
<Package
    xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
    xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
    xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities">

  <Identity Name="MarcoSumari.ingepresupuestos"
            Publisher="CN=EE1CAE53-5428-4D95-AE8B-871AB9D0193C"
            Version="0.0.0.0"
            ProcessorArchitecture="x64" />

  <Properties>
    <DisplayName>IngePresupuestos</DisplayName>
    <PublisherDisplayName>Marco Sumari</PublisherDisplayName>
    <Logo>Assets\StoreLogo.png</Logo>
  </Properties>

  <Dependencies>
    <TargetDeviceFamily Name="Windows.Desktop"
                        MinVersion="10.0.17763.0"
                        MaxVersionTested="10.0.22621.0" />
  </Dependencies>

  <Resources>
    <Resource Language="es-PE" />
  </Resources>

  <Applications>
    <Application Id="IngePresupuestos"
                 Executable="ingepresupuestos.exe"
                 EntryPoint="Windows.FullTrustApplication">
      <uap:VisualElements
          DisplayName="IngePresupuestos"
          Description="Software para la elaboración de presupuestos de obra"
          BackgroundColor="transparent"
          Square150x150Logo="Assets\Square150x150Logo.png"
          Square44x44Logo="Assets\Square44x44Logo.png">
        <uap:DefaultTile Wide310x150Logo="Assets\Wide310x150Logo.png" />
      </uap:VisualElements>
    </Application>
  </Applications>

  <Capabilities>
    <rescap:Capability Name="runFullTrust" />
  </Capabilities>

</Package>
